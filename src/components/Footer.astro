---
const year = new Date().getFullYear();

import "../styles/components/footer.css";

const icons = {
  instagram: "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01M3 7.8C3 5.15 5.15 3 7.8 3h8.4C18.85 3 21 5.15 21 7.8v8.4c0 2.65-2.15 4.8-4.8 4.8H7.8C5.15 21 3 18.85 3 16.2z",
  behance: "M3 6h6a3 3 0 0 1 0 6H3zM3 12h7a3 3 0 0 1 0 6H3zM14 9h7M14 14h7a3 3 0 0 0-6 0",
  linkedin: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z",
  pinterest: "M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.3-5.5s-.3-.7-.3-1.6c0-1.5.9-2.6 2-2.6.9 0 1.4.7 1.4 1.5 0 .9-.6 2.3-.9 3.6-.3 1 .5 1.9 1.6 1.9 1.9 0 3.4-2 3.4-4.9 0-2.6-1.8-4.4-4.5-4.4-3 0-4.8 2.3-4.8 4.6 0 .9.4 1.9.8 2.5l-.3 1.3c-.1.2-.2.3-.4.2-1.4-.7-2.3-2.7-2.3-4.4 0-3.6 2.6-6.9 7.5-6.9 3.9 0 7 2.8 7 6.5 0 3.9-2.5 7.1-5.9 7.1-1.2 0-2.3-.6-2.6-1.3l-.7 2.7c-.3 1-1 2.3-1.4 3.1A10 10 0 1 0 12 2z"
};
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">

      <!-- BRAND -->
      <div class="footer__brand">
        <a href="/" class="logo">
          <img src="Logo.png" alt="SC PROJECTS" class="logo-img">
        </a>

        <p>
          Estudio de arquitectura y diseño con base en Yucatán. Construimos
          silencio, materia y luz desde 2014.
        </p>

        <div class="socials" aria-label="Redes sociales">
          <a href="#" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={icons.instagram} />
            </svg>
          </a>

          <a href="#" aria-label="Behance">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={icons.behance} />
            </svg>
          </a>

          <a href="#" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={icons.linkedin} />
            </svg>
          </a>

          <a href="#" aria-label="Pinterest">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={icons.pinterest} />
            </svg>
          </a>
        </div>
      </div>

      <!-- NAV -->
      <div>
        <h4>Navegación</h4>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/quienes-somos">Quiénes somos</a></li>
          <li><a href="/proyectos">Proyectos</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>

      <!-- INFO -->
      <div>
        <h4>Estudio</h4>
        <ul>
          <li>CALLE 12 POR 9 Y 9A #9, SANTA GERTRUDIS COPÓ, MÉRIDA, YUCATÁN.</li>
          <li>Mérida, Yucatán, México</li>
          <li><a href="mailto:scadmin@scurbanprojects.com">scadmin@scurbanprojects.com</a></li>
          <li><a href="tel:+529992477960">+52 999 247 7960</a></li>
        </ul>
      </div>

    </div>

    <div class="footer__bottom">
      <span>© {year} SC PROJECTS. Todos los derechos reservados.</span>
      <span>Hecho en Yucatán, México.</span>
    </div>
  </div>
</footer>
