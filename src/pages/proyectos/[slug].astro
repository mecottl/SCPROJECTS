---
import MainLayout from "../../layouts/MainLayout.astro";
import { projects } from "../../data/projects";
import "../../styles/pages/projects.css";

// rutas dinámicas
export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

// fallback
if (!project) {
  throw new Error("Proyecto no encontrado");
}

const others = projects
  .filter((p) => p.slug !== project.slug)
  .slice(0, 3);

// 👇 cantidad inicial visible
const INITIAL_COUNT = 12;
const initialGallery = project.gallery.slice(0, INITIAL_COUNT);
---

<MainLayout
  title={`${project.title} — SC PROJECTS`}
  description={project.description[0]}
>

<!-- HERO -->
<section class="project-hero">
  <div class="container">

    <div class="project-hero__title reveal">
      <span class="eyebrow">{project.category} · {project.year}</span>
      <h1>{project.title}</h1>
    </div>

    <div class="project-hero__cover reveal delay-1">
      <!-- 👇 ahora cover es string -->
      <img src={project.cover} alt={project.title} />
    </div>

    <div class="project-meta reveal delay-2">
      <div class="project-meta__item">
        <span>Ubicación</span>
        <strong>{project.location}</strong>
      </div>

      <div class="project-meta__item">
        <span>Superficie</span>
        <strong>{project.area}</strong>
      </div>

      <div class="project-meta__item">
        <span>Año</span>
        <strong>{project.year}</strong>
      </div>

      <div class="project-meta__item">
        <span>Estado</span>
        <strong>{project.status}</strong>
      </div>
    </div>

  </div>
</section>

<!-- BODY -->
<section class="container">

  <div class="project-body">
    <div class="reveal">
      <span class="eyebrow">Memoria del proyecto</span>
    </div>
    
    <div class="reveal delay-1">
      {project.description.map((p) => (
        <p>{p}</p>
      ))}
    </div>
  </div>

  <!-- GALERÍA -->
  <div class="project-grid" id="project-grid">
    {initialGallery.map((g, i) => (
      <div class={`project-grid__item ${g.layout} reveal delay-${i % 4}`}>
        <img
          src={g.src}
          alt={`${project.title} — vista ${i + 1}`}
          loading={i < 4 ? "eager" : "lazy"}
        />
      </div>
    ))}
  </div>

  
</section>
<div id="load-more-trigger" style="height: 100px;"></div>

<!-- OTRAS -->
<section class="section">
  <div class="container">

    <div class="section-head reveal">
      <span class="eyebrow">Otras obras</span>
      <h2>Continuar explorando.</h2>
    </div>

    <div class="gallery">
      {others.map((p) => (
        <a href={`/proyectos/${p.slug}`} class="gallery__item sm reveal">
          <img src={p.cover} alt={p.title} />

          <div class="gallery__caption">
            <div>
              <h3>{p.title}</h3>
              <span>{p.category}</span>
            </div>
            <p class="gallery__year">{p.year}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

</MainLayout>
<script id="gallery-data" type="application/json" set:html={JSON.stringify(project.gallery)}></script>

<script type="module" src="/scripts/gallery.js"></script>
