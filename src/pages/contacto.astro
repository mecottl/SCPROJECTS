---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/pages/contact.css";

let sent = false;

// Manejo server-side (opcional)
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const name = data.get("name");
  const email = data.get("email");
  const message = data.get("message");

  // aquí podrías enviar correo / guardar
  sent = true;
}
---

<MainLayout
  title="Contacto — SC PROJECTS"
  description="Conversemos sobre tu proyecto. Estudio en Mérida, Yucatán."
>
  <!-- HERO -->
  <section class="contact-hero">
    <div class="container">
      <span class="eyebrow reveal">Iniciar conversación</span>

      <h1 class="reveal delay-1" style="margin-top:1.5rem;">
        Conversemos sobre<br /><em>tu proyecto</em>.
      </h1>
    </div>
  </section>

  <!-- FORM -->
  <section class="container">
    <div class="contact-grid">
      <form class="form reveal" method="POST" novalidate>
        <div class="form__row">
          <div class="field">
            <label for="name">Nombre</label>
            <input id="name" name="name" type="text" required />
          </div>

          <div class="field">
            <label for="email">Correo</label>
            <input id="email" name="email" type="email" required />
          </div>
        </div>

        <div class="form__row">
          <div class="field">
            <label for="phone">Teléfono</label>
            <input id="phone" name="phone" type="tel" />
          </div>

          <div class="field">
            <label for="type">Tipo de proyecto</label>
            <select id="type" name="type">
              <option value="">Selecciona</option>
              <option>Residencial</option>
              <option>Comercial</option>
              <option>Hospitalidad</option>
              <option>Cultural</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label for="message">Cuéntanos</label>
          <textarea id="message" name="message" required></textarea>
        </div>

        <button class="btn btn--solid">Enviar mensaje →</button>

        {sent && <div class="toast">Gracias. Te responderemos pronto.</div>}
      </form>

      <!-- INFO -->
      <aside class="contact-info reveal delay-1">
        <div class="contact-info__item">
          <span>Estudio</span>
          <p>CALLE 12 POR 9 Y 9A #9, SANTA GERTRUDIS COPÓ<br />Mérida, Yucatán</p>
        </div>

        <div class="contact-info__item">
          <span>Correo</span><a href="mailto:scadmin@scurbanprojects.com"
            >scadmin@scurbanprojects.com</a
          >
        </div>

        <div class="contact-info__item">
          <span>Teléfono</span>
          <a href="tel:+529992477960">+52 999 247 7960</a>
        </div>
      </aside>
    </div>
  </section>

  <script>
    const form = document.querySelector("form");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();

      form.reset();

      const toast = document.createElement("div");
      toast.className = "toast";
      toast.textContent = "Mensaje enviado";

      form.appendChild(toast);

      setTimeout(() => toast.remove(), 6000);
    });
  </script>
</MainLayout>
